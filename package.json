{
  "name": "walletwall-vault",
  "version": "0.9.22",
  "description": "Research prototype: hybrid classical (ECDSA) + post-quantum withdrawal-authorization vault. Not audited. Testnet/local only.",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test",
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "coverage": "hardhat coverage",
    "deploy": "hardhat run scripts/deploy.ts",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:base-sepolia": "hardhat run scripts/deploy.ts --network base-sepolia",
    "demo": "hardhat run scripts/demo-local.ts",
    "demo:simulator": "hardhat run scripts/demo-simulator.ts",
    "deploy:simulator": "hardhat run scripts/deploy-simulator.ts",
    "deploy:simulator:sepolia": "hardhat run scripts/deploy-simulator.ts --network sepolia",
    "attestor:demo": "ts-node scripts/attestor-cli.ts demo",
    "attestor:verify": "ts-node scripts/attestor-cli.ts verify",
    "attestor:fixtures": "ts-node scripts/generate-attestor-fixture.ts",
    "evidence:fixtures": "ts-node scripts/generate-evidence-fixture.ts",
    "proof:artifact": "ts-node scripts/generate-proof-artifact.ts",
    "proof:artifact:validate": "ts-node scripts/generate-proof-artifact.ts --validate",
    "evidence:manifest": "ts-node scripts/generate-mldsa-evidence-manifest.ts",
    "validate:evidence": "ts-node scripts/generate-mldsa-evidence-manifest.ts --validate",
    "verifier:verify": "ts-node scripts/pq-verifier-cli.ts verify",
    "hosted:demo": "ts-node scripts/hosted-verifier-demo.ts",
    "sp1:smoke": "ts-node scripts/sp1-smoke.ts",
    "sp1:proof-input": "ts-node scripts/generate-sp1-proof-input.ts",
    "validate:sp1-input": "ts-node scripts/generate-sp1-proof-input.ts --validate",
    "zk:adapter": "ts-node scripts/generate-zk-verifier-adapter.ts",
    "validate:zk-adapter": "ts-node scripts/generate-zk-verifier-adapter.ts --validate",
    "zk:adapter:response": "ts-node scripts/generate-zk-adapter-evidence-response.ts",
    "validate:zk-response": "ts-node scripts/generate-zk-adapter-evidence-response.ts --validate",
    "static:artifact": "ts-node scripts/generate-static-evidence-artifact.ts",
    "validate:static-artifact": "ts-node scripts/generate-static-evidence-artifact.ts --validate",
    "static:publish:prepare": "ts-node scripts/prepare-static-evidence-publish.ts",
    "pretypecheck": "hardhat compile",
    "typecheck": "tsc --noEmit",
    "lint": "solhint \"contracts/**/*.sol\"",
    "format": "prettier --write \"contracts/**/*.sol\" \"{src,scripts,test,pqc}/**/*.ts\"",
    "format:check": "prettier --check \"contracts/**/*.sol\" \"{src,scripts,test,pqc}/**/*.ts\"",
    "validate:deployments": "ts-node scripts/validate-deployments.ts",
    "validate:reproducibility": "ts-node scripts/validate-reproducibility.ts"
  },
  "keywords": [
    "solidity",
    "pqc",
    "ethereum",
    "vault",
    "quantum-safe"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@openzeppelin/contracts": "^5.1.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "dotenv": "^17.4.2",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.15",
    "hardhat-gas-reporter": "^2.3.0",
    "prettier": "^3.9.4",
    "prettier-plugin-solidity": "^2.3.1",
    "solhint": "^6.2.3",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.6.1"
  },
  "overrides": {
    "js-yaml": ">=4.2.0"
  }
}
